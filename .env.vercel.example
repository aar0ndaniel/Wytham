# Vercel frontend environment example for the split deployment setup.
# Keep backend secrets on Railway; only frontend-safe values belong here.
# The frontend does not consume these values directly until the deploy config seam
# is added in the later frontend deployment task.

PUBLIC_BASE_URL=https://landing.wytham.app

# Optional client-safe Supabase values if the frontend later needs direct reads.
padi=https://your-project.supabase.co
tsotso=your-project-ref
amenya=your-publishable-key
