# Backend runtime example for local or hosted Wytham landing page services.
# Copy this file to `.env` and replace placeholder values before use.

HOST=127.0.0.1
PORT=8787
ADMIN_HOST=127.0.0.1
ADMIN_PORT=8788
PUBLIC_BASE_URL=https://landing.wytham.app
ALLOWED_ORIGINS=https://landing.wytham.app,http://127.0.0.1:8787,http://localhost:8787

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
HEALTH_TOKEN=health-token-placeholder

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=team@example.com
SMTP_PASS=change-this-smtp-password
SMTP_FROM_NAME=Wytham Team
SMTP_FROM_EMAIL=team@example.com
SUPPORT_EMAIL=support@example.com
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

LITE_SHARE_URL=https://example.com/wytham-lite
BUNDLE_SHARE_URL=https://example.com/wytham-bundle

